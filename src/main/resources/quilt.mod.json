{
  "schema_version": 1,
  "quilt_loader": {
    "group": "com.arnav",
    "id": "tabplus",
    "version": "${version}",
    "metadata": {
      "name": "Tab+",
      "description": "Replaces the vanilla tab list with a social-aware overlay.",
      "contributors": { "arnav": "Owner" },
      "license": "MIT"
    },
    "intermediate_mappings": "net.fabricmc:intermediary",
    "entrypoints": {
      "client_init": ["com.arnav.tabplus.TabPlusClient"]
    },
    "depends": [
      { "id": "quilt_loader", "versions": ">=0.18.0" },
      { "id": "quilted_fabric_api", "versions": "*" },
      { "id": "minecraft", "versions": "~26.1" }
    ]
  },
  "mixin": ["tabplus.client.mixins.json"]
}
